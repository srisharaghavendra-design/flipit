{
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/app", "dest": "/app.html" },
    { "src": "/pricing", "dest": "/pricing.html" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/beat-salesforce", "dest": "/beat-salesforce.html" },
    { "src": "/beat-hubspot", "dest": "/beat-hubspot.html" },
    { "src": "/beat-outreach", "dest": "/beat-outreach.html" },
    { "src": "/beat-gong", "dest": "/beat-gong.html" },
    { "src": "/beat-clari", "dest": "/beat-clari.html" },
    { "src": "/plan", "dest": "/plan.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
